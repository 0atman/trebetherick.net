    <entry xml:lang="en">
        <title>About The Museum</title>
        <published>2025-01-01T00:00:00+00:00</published>
        <updated>2025-01-01T00:00:00+00:00</updated>
        
        <author>
          <name>
            
              The Oaten family &amp; Trebetherick residents and friends
            
          </name>
        </author>
        
        <link rel="alternate" type="text/html" href="https://www.trebetherick.net/about/"/>
        <id>https://www.trebetherick.net/about/</id>
        
        <content type="html" xml:base="https://www.trebetherick.net/about/">&lt;p&gt;Our home is between Polzeath and Rock. It extends west to Daymer Bay and Trebetherick Point, a sandy bay with rocky headland at the mouth of the Camel Estuary, a site of many ancient shipwrecks.&lt;&#x2F;p&gt;
</content>
        
